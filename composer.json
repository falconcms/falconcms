{
    "name": "falconcms/falconcms",
    "description": "FalconCMS — A powerful Laravel CMS with page builder, e-commerce, and admin dashboard.",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Acme\\CmsDashboard\\": "src/",
            "Acme\\CmsDashboard\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Acme\\CmsDashboard\\CmsDashboardServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan vendor:publish --tag=lazy-themes --force",
            "@php artisan vendor:publish --tag=cms-dashboard-assets --force"
        ]
    }
}
