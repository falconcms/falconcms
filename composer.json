{
    "name": "falconcms/falconcms",
    "description": "FalconCMS — A powerful Laravel CMS with page builder, e-commerce, and admin dashboard.",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "FalconCms\\Core\\": "src/",
            "FalconCms\\Core\\Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "FalconCms\\Core\\FalconCmsServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan vendor:publish --tag=falcon-themes --force",
            "@php artisan vendor:publish --tag=falcon-cms-assets --force"
        ]
    }
}
